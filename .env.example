# =============================================================================
# Immigram — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://db.yashimosh.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# AI (LiteLLM Proxy)
# -----------------------------------------------------------------------------
AI_BASE_URL=https://litellm.yashimosh.com/v1
AI_API_KEY=sk-yash-local-ai

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://immigram.yashimosh.com
NEXT_PUBLIC_APP_NAME=Immigram

# -----------------------------------------------------------------------------
# Optional: Payments (Phase 6)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
